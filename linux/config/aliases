git_clean() {
  local remote="${1:-origin}"

  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    printf "Not inside a git repository.\n"
    return 0
  fi

  # Colors only when stdout is a terminal
  local RED BLUE GREEN YELLOW BOLD NC
  if [[ -t 1 ]]; then
    RED=$'\033[0;31m'
    BLUE=$'\033[0;34m'
    GREEN=$'\033[0;32m'
    YELLOW=$'\033[0;33m'
    BOLD=$'\033[1m'
    NC=$'\033[0m'
  else
    RED=""
    BLUE=""
    GREEN=""
    YELLOW=""
    BOLD=""
    NC=""
  fi

  local current_branch
  current_branch="$(git branch --show-current)"

  local protected_branches=("main" "master" "development" "$current_branch")

  is_protected_branch() {
    local branch="$1"
    local protected

    for protected in "${protected_branches[@]}"; do
      [[ "$branch" == "$protected" ]] && return 0
    done

    return 1
  }

  printf "${BOLD}Cleaning Git branches${NC}\n\n"

  local prune_output pruned_count
  prune_output="$(git remote prune "$remote" 2>/dev/null)"
  pruned_count="$(grep -c '^\s*\* \[pruned\]' <<< "$prune_output")"

  declare -A remote_branches=()

  local remote_branch
  while IFS= read -r remote_branch; do
    remote_branch="${remote_branch#"$remote"/}"
    [[ "$remote_branch" == "HEAD" ]] && continue
    remote_branches["$remote_branch"]=1
  done < <(git for-each-ref --format="%(refname:short)" "refs/remotes/$remote")

  local removed_count=0
  local kept_count=0
  local skipped_count=0
  local branch
  local removed_branches=()

  while IFS= read -r branch; do
    if is_protected_branch "$branch"; then
      ((skipped_count++))
      continue
    fi

    if [[ -z "${remote_branches[$branch]:-}" ]]; then
      if git branch -D "$branch" >/dev/null 2>&1; then
        removed_branches+=("$branch")
        ((removed_count++))
      else
        printf "${YELLOW}Could not remove:${NC} %s\n" "$branch"
      fi
    else
      ((kept_count++))
    fi
  done < <(git for-each-ref --format="%(refname:short)" refs/heads)

  if (( removed_count > 0 )); then
    printf "${RED}Removed local branches:${NC}\n"
    printf "  %s\n" "${removed_branches[@]}"
    printf "\n"
  fi

  printf "${BOLD}Summary${NC}\n"
  printf "  ${RED}Removed:${NC} %d local branch(es)\n" "$removed_count"
  printf "  ${BLUE}Kept:${NC}    %d local branch(es) still on %s\n" "$kept_count" "$remote"
  printf "  ${YELLOW}Skipped:${NC} %d protected/current branch(es)\n" "$skipped_count"
  printf "  ${GREEN}Pruned:${NC}  %d stale remote branch(es)\n" "$pruned_count"
}


